# ============================================================
# Cardly Backend – Environment Variables
# ============================================================
# Copy file này thành .env rồi điền giá trị thực vào
#   cp .env.example .env
# File .env KHÔNG được commit lên Git (đã có trong .gitignore)
# ============================================================

# --- MongoDB Atlas ---
# Shared cluster của team (Huy + Khanh dùng chung)
MONGODB_URL=mongodb+srv://Huine:Cardly123@cardly.litnfkr.mongodb.net/?appName=Cardly

# --- JWT Auth ---
# Tự đặt chuỗi bất kỳ, dài ≥ 32 ký tự, giữ bí mật
JWT_SECRET=change-me-to-a-long-random-secret
REFRESH_SECRET=change-me-to-another-long-random-secret

# --- Google Cloud / Gemini ---
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# GCP Service Account JSON (dùng cho Cloud Storage upload ảnh thẻ)
# Paste nội dung file .json vào đây trên 1 dòng, hoặc để trống khi dev local
GCP_CREDENTIALS_JSON=

# Tên GCS bucket chứa ảnh thẻ gốc (để trống khi dev local)
GCP_BUCKET=cardly-bucket

# --- App ---
# dev | staging | production
ENVIRONMENT=dev

# URL frontend (dùng cho CORS)
FRONTEND_URL=http://localhost:3000
